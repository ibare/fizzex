{
  "name": "fizzex",
  "version": "0.1.0",
  "description": "Fizzex - Canvas-based mathematical expression editor. Light and easy formula input.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./headless": {
      "types": "./dist/headless/index.d.ts",
      "import": "./dist/headless/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./tiptap": {
      "types": "./dist/integrations/tiptap/index.d.ts",
      "import": "./dist/integrations/tiptap/index.js"
    },
    "./visualizers/*": "./dist/visualizers/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && vite build -c vite.lib.config.ts && cp -R registries/default dist/visualizers && find dist/visualizers -name '*.test.*' -delete",
    "pack:tgz": "pnpm pack --pack-destination pack",
    "build:types": "tsc -p tsconfig.build.json",
    "build:browser": "vite build -c vite.lib.config.ts",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:layout": "vitest run src/__tests__/layout/*.test.ts",
    "test:layout:watch": "vitest src/__tests__/layout/*.test.ts",
    "test:layout:report": "tsx src/__tests__/layout/report-generator.ts",
    "clean": "rm -rf dist node_modules",
    "extract-glyphs": "tsx scripts/extract-glyph-paths.ts",
    "fuzz:extract": "tsx src/__tests__/fuzz/extract-commands.ts",
    "fuzz:generate": "tsx src/__tests__/fuzz/generator.ts",
    "fuzz:generate:fresh": "tsx src/__tests__/fuzz/generator.ts --seed random",
    "fuzz:refresh": "tsx src/__tests__/fuzz/extract-commands.ts && tsx src/__tests__/fuzz/generator.ts",
    "corpus:build": "tsx src/__tests__/corpus/build-corpus.ts",
    "corpus:test": "vitest run src/__tests__/corpus/corpus.test.ts --test-timeout 120000",
    "corpus:report": "tsx src/__tests__/corpus/run-and-save-report.ts",
    "corpus:compare": "tsx src/__tests__/corpus/comparison-runner.ts",
    "corpus:pdflatex-filter": "tsx src/__tests__/corpus/pdflatex-filter.ts",
    "corpus:full": "pnpm corpus:build && pnpm corpus:pdflatex-filter && pnpm corpus:report && pnpm corpus:compare",
    "corpus:open": "open src/__tests__/corpus/report.html",
    "semantic:validate": "tsx scripts/validate-semantic-data.ts"
  },
  "keywords": [
    "math",
    "formula",
    "editor",
    "canvas",
    "latex",
    "equation",
    "typesetting",
    "mathematics"
  ],
  "author": "ibare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibare/fizzex.git"
  },
  "homepage": "https://ibare.github.io/fizzex",
  "bugs": {
    "url": "https://github.com/ibare/fizzex/issues"
  },
  "sideEffects": false,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "peerDependencies": {
    "@tiptap/core": ">=2.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@jsep-plugin/object": "^1.2.2",
    "jsep": "^1.4.0",
    "nerdamer": "^1.1.13",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tiptap/core": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.10.5",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.0.17",
    "katex": "^0.16.27",
    "mathjax-full": "^3.2.2",
    "opentype.js": "^1.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.17"
  }
}
