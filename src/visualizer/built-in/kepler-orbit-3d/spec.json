{
  "$schema": "fizzex-visualizer/v1",
  "id": "kepler-orbit-3d",
  "catalog": "astronomy/kepler-third",

  "name": { "en": "Earth orbit — 3D", "ko": "지구 궤도 — 3D" },
  "description": {
    "en": "T² = (4π²/GM)·a³. Same anchors as 2D, viewed in a slowly rotating 3D camera.",
    "ko": "T² = (4π²/GM)·a³. 2D와 동일한 앵커를 천천히 회전하는 3D 카메라로 관찰한다."
  },
  "renderer": "3d",

  "scenes": [
    {
      "id": "iss",
      "name": { "en": "ISS", "ko": "ISS" },
      "description": {
        "en": "International Space Station — altitude ~400 km, ~90 min period.",
        "ko": "국제우주정거장 — 고도 ≈ 400 km, 약 90분 주기."
      },
      "style": { "color": "#ffd466", "icon": "🛰️" },
      "params": { "a": 6771 }
    },
    {
      "id": "gps",
      "name": { "en": "GPS", "ko": "GPS" },
      "description": {
        "en": "GPS satellite — altitude ~20,200 km, ~12 h period.",
        "ko": "GPS 위성 — 고도 ≈ 20,200 km, 약 12시간 주기."
      },
      "style": { "color": "#60a5fa", "icon": "📡" },
      "params": { "a": 26560 }
    },
    {
      "id": "geo",
      "name": { "en": "Geostationary", "ko": "정지궤도" },
      "description": {
        "en": "Geostationary orbit — altitude ~35,786 km, exactly 24 h.",
        "ko": "정지궤도 — 고도 ≈ 35,786 km, 정확히 24시간."
      },
      "style": { "color": "#a78bfa", "icon": "🌐" },
      "params": { "a": 42164 }
    },
    {
      "id": "moon",
      "name": { "en": "Moon", "ko": "달" },
      "description": {
        "en": "The Moon — ~27.3 day period.",
        "ko": "달 — 약 27.3일 주기."
      },
      "style": { "color": "#e2e8f0", "icon": "🌙" },
      "params": { "a": 384400 }
    }
  ],

  "state": [
    { "id": "camTheta", "type": "number", "default": 1.0472 },
    { "id": "camPhi", "type": "number", "default": 1.0472 },
    { "id": "camDistance", "type": "number", "default": 4 }
  ],

  "animation": {
    "onFrame": [
      { "set": "state.camTheta", "to": "mod(state.camTheta + frame.dt * 0.15, 2 * pi)" },
      { "set": "state.camDistance", "to": "max((a / 6371) * 1.8, 2.5)" }
    ]
  },

  "camera": {
    "kind": "perspective",
    "fov": 50,
    "near": 0.05,
    "far": 2000,
    "state": {
      "theta": "camTheta",
      "phi": "camPhi",
      "distance": "camDistance"
    }
  },

  "viewports": {},

  "root": {
    "kind": "group",
    "let": {
      "color": "scene.style.color",
      "earthR": "1",
      "orbitR": "a / 6371",
      "GM": "3.98574e14",
      "T": "2 * pi * sqrt(pow(a * 1000, 3) / GM)",
      "angle": "mod(frame.elapsed * 2 * pi * 600 / max(T, 0.001), 2 * pi)",
      "satX": "cos(angle) * orbitR",
      "satZ": "sin(angle) * orbitR",
      "segs": "48"
    },
    "children": [
      {
        "kind": "light",
        "lightType": "ambient",
        "intensity": "if(frame.isDark, 0.5, 0.7)",
        "color": "'#ffffff'"
      },
      {
        "kind": "light",
        "lightType": "directional",
        "intensity": "if(frame.isDark, 1.1, 0.9)",
        "position": ["5", "2", "5"],
        "color": "'#ffffff'"
      },
      {
        "kind": "light",
        "lightType": "directional",
        "intensity": "0.25",
        "position": ["-4", "-1", "-3"],
        "color": "'#4466aa'"
      },

      {
        "kind": "sphere",
        "cx": "0", "cy": "0", "cz": "0",
        "r": "earthR",
        "segments": 48,
        "style": { "fill": "if(frame.isDark, '#2a5f9e', '#4a90d9')" }
      },
      {
        "kind": "sphere",
        "cx": "0", "cy": "0", "cz": "0",
        "r": "earthR * 1.08",
        "segments": 48,
        "style": {
          "fill": "if(frame.isDark, '#5a90ff', '#7aaaff')",
          "opacity": "if(frame.isDark, 0.18, 0.12)"
        }
      },

      {
        "kind": "repeat",
        "of": { "range": [0, "segs"] },
        "as": "i",
        "children": [
          {
            "kind": "bufferLine",
            "points": "[[cos(i / segs * 2 * pi) * orbitR, 0, sin(i / segs * 2 * pi) * orbitR], [cos((i + 1) / segs * 2 * pi) * orbitR, 0, sin((i + 1) / segs * 2 * pi) * orbitR]]",
            "style": {
              "stroke": "if(frame.isDark, '#82b4ff', '#3c78dc')",
              "opacity": 0.5
            }
          }
        ]
      },

      {
        "kind": "sphere",
        "cx": "satX", "cy": "0", "cz": "satZ",
        "r": 0.09,
        "segments": 16,
        "style": {
          "fill": "color",
          "opacity": 0.28
        }
      },
      {
        "kind": "sphere",
        "cx": "satX", "cy": "0", "cz": "satZ",
        "r": 0.04,
        "segments": 16,
        "style": { "fill": "color" }
      }
    ]
  },

  "overlay": {
    "lines": [
      {
        "label": { "en": "T = ", "ko": "T = " },
        "value": "2 * pi * sqrt(pow(a * 1000, 3) / 3.98574e14)",
        "format": ".2f"
      },
      {
        "label": { "en": "v = ", "ko": "v = " },
        "value": "if(2 * pi * sqrt(pow(a * 1000, 3) / 3.98574e14) > 0, 2 * pi * a / (2 * pi * sqrt(pow(a * 1000, 3) / 3.98574e14)), 0)",
        "format": ".2f"
      }
    ]
  }
}
