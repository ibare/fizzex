{
  "$schema": "fizzex-visualizer/v1",
  "id": "quadratic-basketball-2d",
  "catalog": "linear-functions/quadratic-standard",

  "name": { "en": "Quadratic — Basketball", "ko": "농구 자유투 — 이차함수" },
  "description": {
    "en": "Parabola as a basketball shot. c = release height, vertex = peak, second root = landing.",
    "ko": "포물선을 농구 자유투 궤적으로. c = 발사 높이, 꼭짓점 = 최고점, 두 번째 근 = 착지점."
  },
  "renderer": "2d",

  "scenes": [
    {
      "id": "basketball",
      "name": { "en": "Basketball", "ko": "농구" },
      "description": {
        "en": "a<0 for shot trajectory.",
        "ko": "a<0 이면 슛 포물선."
      },
      "style": { "color": "#EA580C", "icon": "🏀" },
      "params": { "a": -0.5, "b": 2.5, "c": 2, "x": 2.5 }
    }
  ],

  "viewports": {
    "main": {
      "kind": "time-value",
      "rect": { "x": "16", "y": "44", "w": "max(1, frame.width - 32)", "h": "max(1, frame.height - 88)" },
      "xMin": "-1",
      "xMax": "max(8, if(b*b - 4*a*c >= 0 && abs(a) > 1e-9, max((-b - sqrt(b*b - 4*a*c)) / (2*a), (-b + sqrt(b*b - 4*a*c)) / (2*a)), if(abs(a) < 1e-9, 4, -b/a)) * 1.25)",
      "yMin": "-0.5",
      "yMax": "max(4, (c - b*b/(4*a)) * 1.3)"
    }
  },

  "root": {
    "kind": "group",
    "let": {
      "brand": "'#EA580C'",
      "D": "b*b - 4*a*c",
      "hasTwoRoots": "D >= 0 && abs(a) > 1e-9",
      "sqD": "if(hasTwoRoots, sqrt(D), 0)",
      "r1": "if(hasTwoRoots, (-b - sqD) / (2*a), 0)",
      "r2": "if(hasTwoRoots, (-b + sqD) / (2*a), 0)",
      "vx": "if(abs(a) < 1e-9, 0, -b/(2*a))",
      "vy": "c - b*b/(4*a)",
      "landX": "if(hasTwoRoots, max(r1, r2), if(abs(a) < 1e-9, 4, -b/a))",
      "xMinV": "-1",
      "xMaxV": "max(8, landX * 1.25)",
      "yMinV": "-0.5",
      "yMaxV": "max(4, vy * 1.3)",
      "areaLeft": "16",
      "areaTop": "44",
      "areaW": "max(1, frame.width - 32)",
      "areaH": "max(1, frame.height - 88)",
      "sxX": "areaW / (xMaxV - xMinV)",
      "sxY": "areaH / (yMaxV - yMinV)",
      "floorCy": "areaTop + (yMaxV - 0) * sxY",
      "launchCx": "areaLeft + (0 - xMinV) * sxX",
      "releaseCy": "areaTop + (yMaxV - c) * sxY",
      "bodyH": "max(36, floorCy - releaseCy + 12)",
      "headR": "8",
      "bodyW": "14",
      "hoopCx": "areaLeft + (landX - xMinV) * sxX",
      "poleH": "70",
      "boardW": "26",
      "boardH": "18",
      "ringTopY": "floorCy - poleH + 8",
      "yCur": "a*x*x + b*x + c",
      "ballYClamped": "max(0, yCur)",
      "ballCx": "areaLeft + (x - xMinV) * sxX",
      "ballCy": "areaTop + (yMaxV - ballYClamped) * sxY",
      "vertexCx": "areaLeft + (vx - xMinV) * sxX",
      "vertexCy": "areaTop + (yMaxV - vy) * sxY"
    },
    "children": [
      {
        "kind": "rect",
        "x": 0,
        "y": 0,
        "w": "frame.width",
        "h": "frame.height",
        "style": {
          "fill": {
            "kind": "linear",
            "x0": "0", "y0": "0", "x1": "0", "y1": "frame.height",
            "stops": [
              [0, "if(frame.isDark, '#111827', '#fef3c7')"],
              [1, "if(frame.isDark, '#1f2937', '#fde68a')"]
            ]
          }
        }
      },

      {
        "kind": "rect",
        "x": 0,
        "y": "floorCy",
        "w": "frame.width",
        "h": "frame.height - floorCy",
        "style": { "fill": "if(frame.isDark, '#78350f', '#a16207')" }
      },
      {
        "kind": "line",
        "x1": 0,
        "y1": "floorCy",
        "x2": "frame.width",
        "y2": "floorCy",
        "style": {
          "stroke": "if(frame.isDark, '#fbbf24', '#7c2d12')",
          "lineWidth": 1.5
        }
      },
      {
        "kind": "repeat",
        "of": { "range": [0, 8] },
        "as": "i",
        "children": [
          {
            "kind": "line",
            "x1": "(i / 8) * frame.width",
            "y1": "floorCy",
            "x2": "(i / 8) * frame.width",
            "y2": "frame.height",
            "style": {
              "stroke": "if(frame.isDark, 'rgba(251,191,36,0.25)', 'rgba(120,53,15,0.35)')",
              "lineWidth": 1
            }
          }
        ]
      },

      {
        "kind": "functionCurve",
        "viewport": "main",
        "fn": "a*x*x + b*x + c",
        "xMin": "xMinV",
        "xMax": "xMaxV",
        "samples": 96,
        "style": {
          "stroke": "hexAlpha(brand, 0.35)",
          "lineWidth": 2,
          "lineDash": [4, 3]
        }
      },

      {
        "kind": "roundRect",
        "x": "launchCx - bodyW / 2",
        "y": "floorCy - bodyH + headR * 2",
        "w": "bodyW",
        "h": "bodyH - headR * 2",
        "r": 4,
        "style": { "fill": "if(frame.isDark, '#cbd5e1', '#1e293b')" }
      },
      {
        "kind": "circle",
        "cx": "launchCx",
        "cy": "floorCy - bodyH + headR",
        "r": "headR",
        "style": { "fill": "if(frame.isDark, '#cbd5e1', '#1e293b')" }
      },
      {
        "kind": "line",
        "x1": "launchCx",
        "y1": "floorCy - bodyH + headR * 2 + 4",
        "x2": "launchCx + 10",
        "y2": "floorCy - bodyH + 2",
        "style": {
          "stroke": "if(frame.isDark, '#cbd5e1', '#1e293b')",
          "lineWidth": 4,
          "lineCap": "round"
        }
      },

      {
        "kind": "rect",
        "x": "hoopCx - 2",
        "y": "floorCy - poleH",
        "w": 4,
        "h": "poleH",
        "style": { "fill": "if(frame.isDark, '#64748b', '#334155')" }
      },
      {
        "kind": "rect",
        "x": "hoopCx - 2 - boardW",
        "y": "ringTopY - boardH / 2",
        "w": "boardW",
        "h": "boardH",
        "style": {
          "fill": "if(frame.isDark, '#cbd5e1', '#f8fafc')",
          "stroke": "if(frame.isDark, '#475569', '#64748b')",
          "lineWidth": 1
        }
      },
      {
        "kind": "line",
        "x1": "hoopCx - 2 - boardW + 2",
        "y1": "ringTopY",
        "x2": "hoopCx - 10",
        "y2": "ringTopY",
        "style": { "stroke": "brand", "lineWidth": 2.5 }
      },
      {
        "kind": "repeat",
        "of": { "range": [0, 5] },
        "as": "i",
        "children": [
          {
            "kind": "line",
            "x1": "hoopCx - 10 + i * 2",
            "y1": "ringTopY",
            "x2": "hoopCx - 10 + i * 2 - 1 + i * 0.3",
            "y2": "ringTopY + 8",
            "style": {
              "stroke": "hexAlpha(brand, 0.5)",
              "lineWidth": 1
            }
          }
        ]
      },

      {
        "kind": "if",
        "cond": "vy > 0 && vx > 0 && vx < xMaxV",
        "then": {
          "kind": "group",
          "children": [
            {
              "kind": "circle",
              "cx": "vertexCx",
              "cy": "vertexCy",
              "r": 10,
              "style": { "fill": "hexAlpha(brand, 0.25)" }
            },
            {
              "kind": "line",
              "x1": "vertexCx",
              "y1": "vertexCy",
              "x2": "vertexCx",
              "y2": "floorCy",
              "style": {
                "stroke": "brand",
                "lineWidth": 1,
                "lineDash": [3, 3]
              }
            },
            {
              "kind": "text",
              "x": "vertexCx",
              "y": "vertexCy - 12",
              "text": "format('최고점 {}m', formatN(vy))",
              "style": {
                "fill": "brand",
                "font": "600 10px -apple-system, sans-serif",
                "textAlign": "center",
                "textBaseline": "bottom"
              }
            }
          ]
        },
        "else": { "kind": "group", "children": [] }
      },

      {
        "kind": "if",
        "cond": "x >= xMinV && x <= xMaxV",
        "then": {
          "kind": "group",
          "children": [
            {
              "kind": "circle",
              "cx": "ballCx + 1",
              "cy": "ballCy + 2",
              "r": 10,
              "style": { "fill": "'rgba(0,0,0,0.2)'" }
            },
            {
              "kind": "circle",
              "cx": "ballCx",
              "cy": "ballCy",
              "r": 10,
              "style": {
                "fill": {
                  "kind": "radial",
                  "cx0": "ballCx - 3",
                  "cy0": "ballCy - 3",
                  "r0": 2,
                  "cx1": "ballCx",
                  "cy1": "ballCy",
                  "r1": 10,
                  "stops": [
                    [0, "'#fdba74'"],
                    [1, "'#c2410c'"]
                  ]
                },
                "stroke": "'#7c2d12'",
                "lineWidth": 1
              }
            },
            {
              "kind": "line",
              "x1": "ballCx - 10",
              "y1": "ballCy",
              "x2": "ballCx + 10",
              "y2": "ballCy",
              "style": { "stroke": "'#7c2d12'", "lineWidth": 1 }
            },
            {
              "kind": "line",
              "x1": "ballCx",
              "y1": "ballCy - 10",
              "x2": "ballCx",
              "y2": "ballCy + 10",
              "style": { "stroke": "'#7c2d12'", "lineWidth": 1 }
            }
          ]
        },
        "else": { "kind": "group", "children": [] }
      },

      {
        "kind": "roundRect",
        "x": 12,
        "y": 12,
        "w": 200,
        "h": 22,
        "r": 6,
        "style": {
          "fill": "if(frame.isDark, 'rgba(15,23,42,0.85)', 'rgba(255,255,255,0.92)')",
          "stroke": "hexAlpha(brand, 0.7)",
          "lineWidth": 1.5
        }
      },
      {
        "kind": "text",
        "x": 112,
        "y": 23,
        "text": "if(landX > 0, format('최고점 {}m · 비거리 {}m', formatN(vy), formatN(landX)), format('최고점 {}m', formatN(vy)))",
        "style": {
          "fill": "brand",
          "font": "600 11px -apple-system, sans-serif",
          "textAlign": "center",
          "textBaseline": "middle"
        }
      },

      {
        "kind": "text",
        "x": "frame.width / 2",
        "y": "frame.height - 8",
        "text": "'슛의 궤적은 언제나 포물선'",
        "style": {
          "fill": "if(frame.isDark, 'rgba(254,243,199,0.85)', 'rgba(120,53,15,0.9)')",
          "font": "500 10px -apple-system, sans-serif",
          "textAlign": "center",
          "textBaseline": "bottom"
        }
      }
    ]
  },

  "overlay": {
    "lines": [
      {
        "label": { "en": "y = ", "ko": "y = " },
        "value": "a*x*x + b*x + c",
        "format": ".3f"
      }
    ]
  }
}
