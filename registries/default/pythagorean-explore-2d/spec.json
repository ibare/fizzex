{
  "$schema": "fizzex-visualizer/v1",
  "id": "pythagorean-explore-2d",
  "catalog": "geometry/pythagorean-theorem",

  "name": { "en": "Pythagorean — Explore 2D", "ko": "피타고라스 자유탐구" },
  "description": {
    "en": "Classical geometric proof: right triangle with three squares on its sides. a² + b² = c².",
    "ko": "직각삼각형과 세 변 위의 정사각형으로 보는 피타고라스 정리. a² + b² = c²."
  },
  "renderer": "2d",

  "userBindings": [
    { "name": "a", "outputKind": "scalar", "required": true },
    { "name": "b", "outputKind": "scalar", "required": true }
  ],

  "scenes": [
    {
      "id": "explore",
      "name": { "en": "Explore", "ko": "자유탐구" },
      "description": {
        "en": "Free exploration of a and b.",
        "ko": "a와 b를 자유롭게 탐색."
      },
      "style": { "color": "#0F172A", "icon": "🔺" },
      "params": { "a": 3, "b": 4 }
    }
  ],

  "viewports": {
    "diagram": {
      "kind": "fit-box",
      "rect": {
        "x": "0",
        "y": "0",
        "w": "frame.width",
        "h": "frame.height"
      },
      "bbox": {
        "minX": "-b",
        "maxX": "a + b",
        "minY": "-a",
        "maxY": "a + b"
      },
      "padding": { "top": 22, "right": 22, "bottom": 22, "left": 22 }
    }
  },

  "root": {
    "kind": "group",
    "let": {
      "brand": "'#0F172A'",
      "bg": "if(frame.isDark, '#0b1220', '#f8fafc')",
      "c": "sqrt(a * a + b * b)",
      "fillAlpha": "if(frame.isDark, 0.18, 0.12)",
      "sqFill": "hexAlpha(brand, fillAlpha)",
      "sqStroke": "hexAlpha(brand, 0.75)",
      "tickSize": "min(a, b) * 0.08",
      "labelColor": "if(frame.isDark, 'rgba(235,240,250,0.9)', 'rgba(30,40,55,0.92)')",
      "tickColor": "if(frame.isDark, 'rgba(235,240,250,0.7)', 'rgba(30,40,55,0.7)')"
    },
    "children": [
      {
        "kind": "rect",
        "x": "0",
        "y": "0",
        "w": "frame.width",
        "h": "frame.height",
        "style": { "fill": "bg" }
      },

      {
        "kind": "polygon",
        "viewport": "diagram",
        "points": "[[0, 0], [a, 0], [a, -a], [0, -a]]",
        "style": { "fill": "sqFill", "stroke": "sqStroke", "lineWidth": 1.2 }
      },
      {
        "kind": "polygon",
        "viewport": "diagram",
        "points": "[[0, 0], [0, b], [-b, b], [-b, 0]]",
        "style": { "fill": "sqFill", "stroke": "sqStroke", "lineWidth": 1.2 }
      },
      {
        "kind": "polygon",
        "viewport": "diagram",
        "points": "[[a, 0], [0, b], [b, a + b], [a + b, a]]",
        "style": { "fill": "sqFill", "stroke": "sqStroke", "lineWidth": 1.2 }
      },

      {
        "kind": "polygon",
        "viewport": "diagram",
        "points": "[[0, 0], [a, 0], [0, b]]",
        "style": {
          "stroke": "brand",
          "lineWidth": 2.5,
          "lineCap": "round",
          "lineJoin": "round"
        }
      },

      {
        "kind": "polyline",
        "viewport": "diagram",
        "points": "[[tickSize, 0], [tickSize, tickSize], [0, tickSize]]",
        "style": { "stroke": "tickColor", "lineWidth": 1.2 }
      },

      {
        "kind": "text",
        "viewport": "diagram",
        "x": "a / 2",
        "y": "-a / 2",
        "text": "format('a² = {}', formatN(a * a))",
        "style": {
          "fill": "labelColor",
          "font": "'600 11px -apple-system, sans-serif'",
          "textAlign": "center",
          "textBaseline": "middle"
        }
      },
      {
        "kind": "text",
        "viewport": "diagram",
        "x": "-b / 2",
        "y": "b / 2",
        "text": "format('b² = {}', formatN(b * b))",
        "style": {
          "fill": "labelColor",
          "font": "'600 11px -apple-system, sans-serif'",
          "textAlign": "center",
          "textBaseline": "middle"
        }
      },
      {
        "kind": "text",
        "viewport": "diagram",
        "x": "(a + b) / 2",
        "y": "(a + b) / 2",
        "text": "format('c² = {}', formatN(c * c))",
        "style": {
          "fill": "labelColor",
          "font": "'600 11px -apple-system, sans-serif'",
          "textAlign": "center",
          "textBaseline": "middle"
        }
      },

      {
        "kind": "text",
        "viewport": "diagram",
        "x": "a / 2",
        "y": "0",
        "text": "format('a = {}', formatN(a))",
        "style": {
          "fill": "brand",
          "font": "'500 11px -apple-system, sans-serif'",
          "textAlign": "center",
          "textBaseline": "bottom"
        }
      },
      {
        "kind": "text",
        "viewport": "diagram",
        "x": "0",
        "y": "b / 2",
        "text": "format('b = {}', formatN(b))",
        "style": {
          "fill": "brand",
          "font": "'500 11px -apple-system, sans-serif'",
          "textAlign": "left",
          "textBaseline": "middle"
        }
      },
      {
        "kind": "text",
        "viewport": "diagram",
        "x": "a / 2",
        "y": "b / 2",
        "text": "format('c = {}', formatN(c))",
        "style": {
          "fill": "brand",
          "font": "'500 11px -apple-system, sans-serif'",
          "textAlign": "center",
          "textBaseline": "bottom"
        }
      }
    ]
  },

  "overlay": {
    "lines": [
      {
        "label": { "en": "c = ", "ko": "c = " },
        "value": "sqrt(a * a + b * b)",
        "format": ".3f"
      }
    ]
  }
}
